{
  "name": "claude-kanban",
  "version": "0.0.0",
  "private": true,
  "description": "A kanban board for Claude Agent SDK runs (local mode). See README.md and CLAUDE.md.",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:protocol": "node --import tsx --test 'src/protocol/*.test.ts'",
    "test:store": "node --import tsx --test 'src/lib/store/*.test.ts'",
    "test:worker": "node --import tsx --test 'src/worker/*.test.ts'",
    "test:supervisor": "node --import tsx --test 'src/lib/supervisor/*.test.ts'",
    "test": "node --import tsx --test 'src/protocol/*.test.ts' 'src/lib/store/*.test.ts' 'src/worker/*.test.ts' 'src/lib/supervisor/*.test.ts'"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.123",
    "ulid": "^3.0.2",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
